# ── Frontend environment variables ───────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env — it is listed in .gitignore.

# Supabase project URL (safe to expose — your Supabase dashboard → Settings → API)
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co

# Supabase anon/public key (safe to expose — security enforced by RLS policies)
VITE_SUPABASE_ANON_KEY=eyJ...

# Backend API base URL — set this to your Express backend's public URL (no trailing slash)
# In development this is empty (Vite proxy handles /api → localhost:5000)
# In production set it to the backend's domain, e.g. https://backend.up.railway.app
VITE_API_URL=
