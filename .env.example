# ── Frontend environment variables ───────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env — it is listed in .gitignore.

# Supabase project URL (safe to expose — your Supabase dashboard → Settings → API)
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co

# Supabase anon/public key (safe to expose — security enforced by RLS policies)
VITE_SUPABASE_ANON_KEY=eyJ...

# Backend API URL — set this to your Express backend's public URL (no trailing slash)
# Used to trigger meeting invitation emails after Supabase creates the meeting
# Example (Railway): https://your-backend-service.up.railway.app
VITE_BACKEND_URL=http://localhost:5000
