# Server
PORT=5000
NODE_ENV=development

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# MinIO (S3-compatible storage)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key
MINIO_BUCKET=gpp-uploads
MINIO_USE_SSL=false

# Redis (for BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379

# Email (Nodemailer — Gmail SMTP)
# SMTP_HOST must be smtp.gmail.com for Gmail
# SMTP_PORT: use 587 (STARTTLS) or 465 (SSL)
# SMTP_USER: your Gmail address
# SMTP_PASS: Gmail App Password (NOT your account password)
#   → Generate at: myaccount.google.com → Security → 2-Step Verification → App passwords
# EMAIL_FROM: display name + address shown to recipients
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_16char_app_password
EMAIL_FROM="FCIT Graduation Platform <your_gmail@gmail.com>"

# Admin Account (for create-admin script: npm run create-admin)
ADMIN_EMAIL=your_admin@email.com
ADMIN_PASSWORD=your_admin_password
ADMIN_NAME=Admin Name
